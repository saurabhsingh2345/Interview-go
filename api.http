@baseUrl = http://localhost:8113
@interviewId = 1
@responseId = 456
# Mint with: go run ./cmd/partner -name "Acme" -email dev@acme.com
@apiKey = sk_live_replace_me

### 1. Create interview (partner API key) -> returns redirect_url
POST {{baseUrl}}/api/v1/interviews
Content-Type: application/json
Authorization: Bearer {{apiKey}}

{
  "topic": "Senior Go Engineer — concurrency & systems",
  "candidate_name": "Asha Rao",
  "candidate_email": "asha@acme.com",
  "external_id": "acme-user-9981",
  "redirect_url": "https://acme.com/interviews/done",
  "callback_url": "https://acme.com/hooks/interview"
}

### 2. Open the redirect_url from the response in a browser.
###    (The candidate app calls /session/exchange for you — shown here for reference.)
POST {{baseUrl}}/api/v1/session/exchange
Content-Type: application/json

{
  "token": "paste-the-t-query-param-from-redirect_url"
}

### 3a. Poll interview status until "completed" (partner API key)
GET {{baseUrl}}/api/v1/interviews/{{interviewId}}
Authorization: Bearer {{apiKey}}

### 3b. Get the report (partner API key; 400 until completed)
GET {{baseUrl}}/api/v1/interviews/{{interviewId}}/report
Authorization: Bearer {{apiKey}}

### Optional: full transcript
GET {{baseUrl}}/api/v1/interviews/{{interviewId}}/transcript
Authorization: Bearer {{apiKey}}

### Optional: aggregated evaluation
GET {{baseUrl}}/api/v1/interviews/{{interviewId}}/evaluation
Authorization: Bearer {{apiKey}}

### List your interviews
GET {{baseUrl}}/api/v1/interviews
Authorization: Bearer {{apiKey}}
